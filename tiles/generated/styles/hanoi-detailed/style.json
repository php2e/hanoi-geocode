{
  "version": 8,
  "name": "Hanoi Detailed",
  "metadata": {
    "description": "Detailed OpenStreetMap-like style for the local Hanoi tilemaker MBTiles."
  },
  "sources": {
    "v3": {
      "type": "vector",
      "tiles": [
        "http://localhost:8080/data/v3/{z}/{x}/{y}.pbf"
      ],
      "minzoom": 0,
      "maxzoom": 14,
      "bounds": [105.28, 20.53, 106.05, 21.39]
    }
  },
  "glyphs": "http://localhost:8080/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f2efe9"
      }
    },
    {
      "id": "landcover-low",
      "type": "fill",
      "source": "v3",
      "source-layer": "landcover",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "wood", "#c8dfb7",
          "grass", "#d5e8c2",
          "scrub", "#d7e5bf",
          "sand", "#eee1b8",
          "#e7ead8"
        ],
        "fill-opacity": 0.68
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "v3",
      "source-layer": "landuse",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "residential", "#ece7dd",
          "suburb", "#ece7dd",
          "neighbourhood", "#ece7dd",
          "industrial", "#eadde4",
          "commercial", "#efe0d3",
          "retail", "#f1ded5",
          "school", "#efe9c9",
          "hospital", "#f2dada",
          "cemetery", "#d8e4cf",
          "agriculture", "#eee8d5",
          "#ebe6dc"
        ],
        "fill-opacity": 0.72
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "v3",
      "source-layer": "park",
      "minzoom": 10,
      "paint": {
        "fill-color": "#cfe8bf",
        "fill-opacity": 0.86
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "v3",
      "source-layer": "water",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#a9d6f2"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "v3",
      "source-layer": "waterway",
      "filter": ["==", "$type", "LineString"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#89c3e8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.7, 12, 1.4, 16, 5, 19, 11],
        "line-opacity": ["case", ["==", ["get", "brunnel"], "tunnel"], 0.45, 1]
      }
    },
    {
      "id": "aeroway-area",
      "type": "fill",
      "source": "v3",
      "source-layer": "aeroway",
      "filter": ["all", ["==", "$type", "Polygon"], ["in", "class", "runway", "taxiway"]],
      "minzoom": 11,
      "paint": {
        "fill-color": "#dedbd4",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "v3",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#d7d0c4",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0.55, 15, 0.9],
        "fill-outline-color": "#c1b9ad"
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "v3",
      "source-layer": "boundary",
      "paint": {
        "line-color": "#9c8fb0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.45, 12, 0.8, 16, 1.4],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 7, 0.28, 12, 0.45],
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "road-path-casing",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "path", "track"]],
      "minzoom": 13,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#c9c4b9",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 1.2, 16, 3, 19, 7],
        "line-opacity": 0.75
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "minor", "minor_road", "service", "residential", "living_street"]],
      "minzoom": 12,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d0cbc0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 14, 3.2, 16, 7, 19, 18],
        "line-opacity": ["case", ["==", ["get", "brunnel"], "tunnel"], 0.45, 1]
      }
    },
    {
      "id": "road-major-casing",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "motorway", "trunk", "primary", "secondary", "tertiary"]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match",
          ["get", "class"],
          "motorway", "#d99564",
          "trunk", "#e4a765",
          "primary", "#e8b86f",
          "secondary", "#d9bd7b",
          "tertiary", "#cfc5a2",
          "#cfc5a2"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 1.1, 10, 2.2, 13, 5.5, 16, 11, 19, 26],
        "line-opacity": ["case", ["==", ["get", "brunnel"], "tunnel"], 0.55, 1]
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "path", "track"]],
      "minzoom": 13,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#f7f6f1",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.8, 16, 1.8, 19, 4.5],
        "line-dasharray": [1.2, 1],
        "line-opacity": 0.95
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "minor", "minor_road", "service", "residential", "living_street"]],
      "minzoom": 12,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.9, 14, 2.2, 16, 5, 19, 14],
        "line-opacity": ["case", ["==", ["get", "brunnel"], "tunnel"], 0.62, 1]
      }
    },
    {
      "id": "road-major",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "motorway", "trunk", "primary", "secondary", "tertiary"]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match",
          ["get", "class"],
          "motorway", "#f7c79c",
          "trunk", "#f8d49d",
          "primary", "#f9dfa8",
          "secondary", "#fff0bd",
          "tertiary", "#fff7d1",
          "#ffffff"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.65, 10, 1.5, 13, 3.8, 16, 8, 19, 21],
        "line-opacity": ["case", ["==", ["get", "brunnel"], "tunnel"], 0.7, 1]
      }
    },
    {
      "id": "railway",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "rail", "transit"]],
      "minzoom": 11,
      "paint": {
        "line-color": "#8f8f8f",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.6, 16, 1.4, 19, 3],
        "line-opacity": 0.72,
        "line-dasharray": [0.5, 0.5]
      }
    },
    {
      "id": "aeroway-line",
      "type": "line",
      "source": "v3",
      "source-layer": "aeroway",
      "filter": ["==", "$type", "LineString"],
      "minzoom": 11,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d4d0c8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 2, 15, 8, 18, 24]
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "transportation_name",
      "filter": ["all", ["==", "$type", "LineString"], ["any", ["has", "name:latin"], ["has", "ref"]]],
      "minzoom": 12,
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": ["interpolate", ["linear"], ["zoom"], 12, 280, 16, 450],
        "text-field": ["coalesce", ["get", "name:latin"], ["get", "ref"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 15, 12, 18, 14],
        "text-letter-spacing": 0,
        "text-rotation-alignment": "map",
        "text-pitch-alignment": "viewport"
      },
      "paint": {
        "text-color": "#5d5145",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2,
        "text-halo-blur": 0.5
      }
    },
    {
      "id": "waterway-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "waterway",
      "filter": ["all", ["==", "$type", "LineString"], ["has", "name:latin"]],
      "minzoom": 13,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 10, 17, 13],
        "text-letter-spacing": 0
      },
      "paint": {
        "text-color": "#3f8dbd",
        "text-halo-color": "#e7f5ff",
        "text-halo-width": 1.8
      }
    },
    {
      "id": "water-name",
      "type": "symbol",
      "source": "v3",
      "source-layer": "water_name",
      "filter": ["has", "name:latin"],
      "minzoom": 13,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 11, 16, 14],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#2f83b7",
        "text-halo-color": "#e7f5ff",
        "text-halo-width": 1.8
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "poi",
      "filter": ["all", ["==", "$type", "Point"], ["has", "name:latin"]],
      "minzoom": 14,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 10.5, 17, 12],
        "text-max-width": 9,
        "text-offset": [0, 0.5],
        "text-anchor": "top",
        "text-padding": 2
      },
      "paint": {
        "text-color": [
          "match",
          ["get", "class"],
          "park", "#3d7f3a",
          "school", "#6f5a2f",
          "hospital", "#9a4c54",
          "restaurant", "#8b5a2b",
          "#5f5a50"
        ],
        "text-halo-color": "#ffffff",
        "text-halo-width": 2,
        "text-halo-blur": 0.3
      }
    },
    {
      "id": "poi-detail-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "poi_detail",
      "filter": ["all", ["==", "$type", "Point"], ["has", "name:latin"]],
      "minzoom": 16,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 16, 10, 19, 12],
        "text-max-width": 8,
        "text-offset": [0, 0.5],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#6a6256",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.8
      }
    },
    {
      "id": "aerodrome-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "aerodrome_label",
      "filter": ["has", "name:latin"],
      "minzoom": 10,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 11, 14, 13],
        "text-max-width": 8,
        "text-offset": [0, 0.6],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#64646b",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "mountain-peak-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "mountain_peak",
      "filter": ["has", "name:latin"],
      "minzoom": 12,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "text-max-width": 8,
        "text-offset": [0, 0.5],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#6b5f54",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.8
      }
    },
    {
      "id": "place-other-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "place",
      "filter": ["all", ["==", "$type", "Point"], ["has", "name:latin"], ["!in", "class", "city", "town"]],
      "minzoom": 9,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 10, 13, 12, 16, 14],
        "text-max-width": 9
      },
      "paint": {
        "text-color": "#4a4540",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-city-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "place",
      "filter": ["all", ["==", "$type", "Point"], ["has", "name:latin"], ["in", "class", "city", "town"]],
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 14, 10, 18, 14, 22],
        "text-max-width": 10
      },
      "paint": {
        "text-color": "#302d2a",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2.2
      }
    }
  ],
  "id": "hanoi-detailed"
}
