{
  "version": 8,
  "name": "Hanoi Detailed",
  "metadata": {
    "description": "Readable Hanoi style for local tilemaker MBTiles, tuned for sparse labels and geocode overlays."
  },
  "sources": {
    "v3": {
      "type": "vector",
      "tiles": [
        "http://localhost:8080/data/v3/{z}/{x}/{y}.pbf"
      ],
      "minzoom": 0,
      "maxzoom": 14,
      "bounds": [105.28, 20.53, 106.05, 21.39]
    }
  },
  "glyphs": "http://localhost:8080/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f5f3ee"
      }
    },
    {
      "id": "landcover-low",
      "type": "fill",
      "source": "v3",
      "source-layer": "landcover",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "wood", "#d2e6c7",
          "grass", "#dceccd",
          "scrub", "#dce8ca",
          "sand", "#f0e6c7",
          "#ececdd"
        ],
        "fill-opacity": 0.58
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "v3",
      "source-layer": "landuse",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "residential", "#ece7dd",
          "suburb", "#ece7dd",
          "neighbourhood", "#ece7dd",
          "industrial", "#ebe3e2",
          "commercial", "#efe5dc",
          "retail", "#f0e5de",
          "school", "#f0eccf",
          "hospital", "#f1dddd",
          "cemetery", "#dce7d3",
          "agriculture", "#eee8d5",
          "#eee9df"
        ],
        "fill-opacity": 0.58
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "v3",
      "source-layer": "park",
      "minzoom": 10,
      "paint": {
        "fill-color": "#d8edcc",
        "fill-opacity": 0.76
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "v3",
      "source-layer": "water",
      "filter": ["==", "$type", "Polygon"],
      "paint": {
        "fill-color": "#b9ddf2"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "v3",
      "source-layer": "waterway",
      "filter": ["==", "$type", "LineString"],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#99cceb",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.6, 12, 1.2, 16, 4, 19, 9],
        "line-opacity": ["case", ["==", ["get", "brunnel"], "tunnel"], 0.45, 1]
      }
    },
    {
      "id": "aeroway-area",
      "type": "fill",
      "source": "v3",
      "source-layer": "aeroway",
      "filter": ["all", ["==", "$type", "Polygon"], ["in", "class", "runway", "taxiway"]],
      "minzoom": 11,
      "paint": {
        "fill-color": "#dedbd4",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "v3",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#ded9cf",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0.38, 15, 0.7, 18, 0.82],
        "fill-outline-color": "#cdc7bc"
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "v3",
      "source-layer": "boundary",
      "paint": {
        "line-color": "#b0a5bb",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.35, 12, 0.7, 16, 1.1],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 7, 0.2, 12, 0.34],
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "road-path-casing",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "path", "track"]],
      "minzoom": 13,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d5d0c6",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 1, 16, 2.4, 19, 6],
        "line-opacity": 0.58
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "minor", "minor_road", "service", "residential", "living_street"]],
      "minzoom": 12,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d7d2c8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.1, 14, 2.5, 16, 5.5, 19, 15],
        "line-opacity": ["case", ["==", ["get", "brunnel"], "tunnel"], 0.35, 0.72]
      }
    },
    {
      "id": "road-major-casing",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "motorway", "trunk", "primary", "secondary", "tertiary"]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match",
          ["get", "class"],
          "motorway", "#e1a15f",
          "trunk", "#e7ad66",
          "primary", "#e9bc72",
          "secondary", "#e2ca91",
          "tertiary", "#ded5b2",
          "#ded5b2"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.9, 10, 1.8, 13, 4.5, 16, 9, 19, 22],
        "line-opacity": ["case", ["==", ["get", "brunnel"], "tunnel"], 0.45, 0.86]
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "path", "track"]],
      "minzoom": 13,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#fbfaf6",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.6, 16, 1.5, 19, 4],
        "line-dasharray": [1.2, 1],
        "line-opacity": 0.72
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "minor", "minor_road", "service", "residential", "living_street"]],
      "minzoom": 12,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.7, 14, 1.8, 16, 4.2, 19, 12],
        "line-opacity": ["case", ["==", ["get", "brunnel"], "tunnel"], 0.52, 0.9]
      }
    },
    {
      "id": "road-major",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "motorway", "trunk", "primary", "secondary", "tertiary"]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": [
          "match",
          ["get", "class"],
          "motorway", "#f4c28f",
          "trunk", "#f6d097",
          "primary", "#f8dda5",
          "secondary", "#fff1c5",
          "tertiary", "#fff7da",
          "#ffffff"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.5, 10, 1.2, 13, 3.1, 16, 6.8, 19, 18],
        "line-opacity": ["case", ["==", ["get", "brunnel"], "tunnel"], 0.62, 0.96]
      }
    },
    {
      "id": "railway",
      "type": "line",
      "source": "v3",
      "source-layer": "transportation",
      "filter": ["all", ["==", "$type", "LineString"], ["in", "class", "rail", "transit"]],
      "minzoom": 11,
      "paint": {
        "line-color": "#8f8f8f",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.6, 16, 1.4, 19, 3],
        "line-opacity": 0.72,
        "line-dasharray": [0.5, 0.5]
      }
    },
    {
      "id": "aeroway-line",
      "type": "line",
      "source": "v3",
      "source-layer": "aeroway",
      "filter": ["==", "$type", "LineString"],
      "minzoom": 11,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#d4d0c8",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 2, 15, 8, 18, 24]
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "transportation_name",
      "filter": ["all", ["==", "$type", "LineString"], ["any", ["has", "name:latin"], ["has", "ref"]]],
      "minzoom": 13,
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": ["interpolate", ["linear"], ["zoom"], 13, 420, 16, 620, 19, 860],
        "text-field": ["coalesce", ["get", "name:latin"], ["get", "ref"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 9, 16, 10.5, 19, 12],
        "text-letter-spacing": 0,
        "text-rotation-alignment": "map",
        "text-pitch-alignment": "viewport"
      },
      "paint": {
        "text-color": "#746a5d",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.8,
        "text-halo-blur": 0.5
      }
    },
    {
      "id": "waterway-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "waterway",
      "filter": ["all", ["==", "$type", "LineString"], ["has", "name:latin"]],
      "minzoom": 13,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 10, 17, 13],
        "text-letter-spacing": 0
      },
      "paint": {
        "text-color": "#3f8dbd",
        "text-halo-color": "#e7f5ff",
        "text-halo-width": 1.8
      }
    },
    {
      "id": "water-name",
      "type": "symbol",
      "source": "v3",
      "source-layer": "water_name",
      "filter": ["has", "name:latin"],
      "minzoom": 13,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 11, 16, 14],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#2f83b7",
        "text-halo-color": "#e7f5ff",
        "text-halo-width": 1.8
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "poi",
      "filter": [
        "all",
        ["==", "$type", "Point"],
        ["has", "name:latin"],
        ["any", ["!has", "rank"], ["<=", "rank", 4]]
      ],
      "minzoom": 16,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 16, 10, 18, 11.5],
        "text-max-width": 8,
        "text-offset": [0, 0.5],
        "text-anchor": "top",
        "text-padding": 6,
        "symbol-sort-key": ["coalesce", ["get", "rank"], 99]
      },
      "paint": {
        "text-color": [
          "match",
          ["get", "class"],
          "park", "#3d7f3a",
          "school", "#6f5a2f",
          "hospital", "#9a4c54",
          "restaurant", "#8b5a2b",
          "#5f5a50"
        ],
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.8,
        "text-halo-blur": 0.3
      }
    },
    {
      "id": "poi-detail-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "poi_detail",
      "filter": ["all", ["==", "$type", "Point"], ["has", "name:latin"]],
      "minzoom": 17,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 17, 9.5, 19, 11],
        "text-max-width": 8,
        "text-offset": [0, 0.5],
        "text-anchor": "top",
        "text-padding": 8
      },
      "paint": {
        "text-color": "#746d62",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.6
      }
    },
    {
      "id": "aerodrome-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "aerodrome_label",
      "filter": ["has", "name:latin"],
      "minzoom": 10,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 11, 14, 13],
        "text-max-width": 8,
        "text-offset": [0, 0.6],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#64646b",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "mountain-peak-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "mountain_peak",
      "filter": ["has", "name:latin"],
      "minzoom": 12,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11,
        "text-max-width": 8,
        "text-offset": [0, 0.5],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#6b5f54",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.8
      }
    },
    {
      "id": "place-other-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "place",
      "filter": ["all", ["==", "$type", "Point"], ["has", "name:latin"], ["!in", "class", "city", "town"]],
      "minzoom": 9,
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 9, 9, 13, 11, 16, 12.5],
        "text-max-width": 9,
        "text-padding": 10
      },
      "paint": {
        "text-color": "#54504a",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.8
      }
    },
    {
      "id": "place-city-label",
      "type": "symbol",
      "source": "v3",
      "source-layer": "place",
      "filter": ["all", ["==", "$type", "Point"], ["has", "name:latin"], ["in", "class", "city", "town"]],
      "layout": {
        "text-field": ["get", "name:latin"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 5, 14, 10, 17, 14, 20],
        "text-max-width": 10,
        "text-padding": 12
      },
      "paint": {
        "text-color": "#35322f",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2.2
      }
    }
  ],
  "id": "hanoi-detailed"
}
